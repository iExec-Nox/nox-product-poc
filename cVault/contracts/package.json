{
  "name": "contracts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "clean": "hardhat clean",
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "test": "hardhat test nodejs test/unit",
    "test:unit": "hardhat test nodejs test/unit",
    "deploy:factory": "hardhat ignition deploy ignition/modules/ConfidentialVaultFactory.ts --build-profile production",
    "deploy:factory:arbitrumSepolia": "dotenv -e .env -- hardhat ignition deploy --network arbitrumSepolia --deployment-id arbitrumSepolia ignition/modules/ConfidentialVaultFactory.ts --build-profile production --verify",
    "deploy:vault:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/deployVault.ts",
    "vault:request:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/requestDeposit.ts",
    "vault:claim:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/claimDeposit.ts",
    "vault:requestRedeem:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/requestRedeem.ts",
    "vault:claimRedeem:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/claimRedeem.ts",
    "vault:lifecycle:arbitrumSepolia": "dotenv -e .env -- hardhat run --network arbitrumSepolia scripts/vaultLifecycle.ts",
    "test:e2e:arbitrumSepolia": "dotenv -e .env -- hardhat test nodejs test/e2e/ConfidentialERC7540.e2e.ts",
    "verify:factory": "hardhat ignition verify arbitrumSepolia --network arbitrumSepolia",
    "verify:vault": "dotenv -e .env -- hardhat verify --network arbitrumSepolia"
  },
  "devDependencies": {
    "@iexec-nox/handle": "^0.1.0-beta.10",
    "@nomicfoundation/hardhat-ignition": "^3.1.2",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.4",
    "@types/node": "^22.19.17",
    "dotenv-cli": "^11.0.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.4.0",
    "typescript": "~5.8.0",
    "viem": "^2.48.4"
  },
  "dependencies": {
    "@iexec-nox/nox-confidential-contracts": "^0.1.0",
    "@iexec-nox/nox-protocol-contracts": "^0.2.2",
    "@openzeppelin/contracts": "^5.6.1"
  }
}
