# ── Chain ────────────────────────────────────────────────────────────────────
SETTLER_CHAIN__RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
SETTLER_CHAIN__PRIVATE_KEY=0x

# Factory contract that emits VaultCreated(owner, vaultAddr, label)
SETTLER_CHAIN__FACTORY_ADDRESS=0x

# Block to start indexing from — set to the factory deployment block
# to avoid scanning the entire chain history.
SETTLER_CHAIN__START_BLOCK=0

# Number of confirmations to wait before indexing a block. Default: 1.
# SETTLER_CHAIN__CONFIRMATION_DEPTH=1

# EIP-1559 gas caps (wei). When unset, alloy uses the RPC's suggestion.
# SETTLER_CHAIN__MAX_FEE_PER_GAS=100000000
# SETTLER_CHAIN__MAX_PRIORITY_FEE_PER_GAS=1000000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path. WAL mode is enabled automatically.
SETTLER_DB__PATH=settler.db

# ── HTTP server ──────────────────────────────────────────────────────────────
# SETTLER_SERVER__HOST=127.0.0.1
SETTLER_SERVER__PORT=3001

# ── Indexer (watcher) ────────────────────────────────────────────────────────
# All values optional, defaults shown.
# SETTLER_INDEXER__POLL_INTERVAL_SECS=5
# SETTLER_INDEXER__CHUNK_SIZE=100
# SETTLER_INDEXER__BACKOFF_INITIAL_SECS=1
# SETTLER_INDEXER__BACKOFF_MAX_SECS=60

# ── Processor ────────────────────────────────────────────────────────────────
# All values optional, defaults shown.
# SETTLER_PROCESSOR__POLL_INTERVAL_SECS=5
# SETTLER_PROCESSOR__MAX_ATTEMPTS=5
# SETTLER_PROCESSOR__CONFIRM_TIMEOUT_SECS=120
# SETTLER_PROCESSOR__BACKOFF_BASE_SECS=5

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=settler=info
